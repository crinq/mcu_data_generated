              "name": "DRDY",
              "bit_offset": 0,
              "bit_width": 1,
              "description": "Data ready Note: If IE=1 in RNG_CR, an interrupt is generated when DRDY=1. It can rise when the peripheral is disabled. When the output buffer becomes empty (after reading RNG_DR), this bit returns to 0 until a new random value is generated.",
              "access": "read-only",
              "enum_values": [
                {
                  "name": "Invalid",
                  "value": 0,
                  "description": "The RNG_DR register is not yet valid, no random data is available"
                },
                {
                  "name": "Valid",
                  "value": 1,
                  "description": "The RNG_DR register contains valid random data. Once the RNG_DR register has been read, this bit returns to 0 until a new random value is generated."
                }
              ]
            },
            {
              "name": "CECS",
              "bit_offset": 1,
              "bit_width": 1,
              "description": "Clock error current status Note: This bit is meaningless if CED (Clock error detection) bit in RNG_CR is equal to 1.",
              "access": "read-only",
              "enum_values": [
                {
                  "name": "Correct",
                  "value": 0,
                  "description": "The RNG clock is correct. If the CEIS bit is set, this means that a slow clock was detected and the situation has been recovered."
                },
                {
                  "name": "Slow",
                  "value": 1,
                  "description": "The RNG clock is too slow"
                }
              ]
            },
            {
              "name": "SECS",
              "bit_offset": 2,
              "bit_width": 1,
              "description": "Seed error current status ** More than 64 consecutive bits at the same value (0 or 1) ** More than 32 consecutive alternances of 0 and 1 (0101010101...01)",
              "access": "read-only",
              "enum_values": [
                {
                  "name": "NoFault",
                  "value": 0,
                  "description": "No faulty sequence has currently been detected. If the SEIS bit is set, this means that a faulty sequence was detected and the situation has been recovered."
                },
                {
                  "name": "Fault",
                  "value": 1,
                  "description": "At least one faulty sequence has been detected - see ref manual for details"
                }
              ]
            },
            {
              "name": "CEIS",
              "bit_offset": 5,
              "bit_width": 1,
              "description": "Clock error interrupt status This bit is set at the same time as CECS. It is cleared by writing it to 0. An interrupt is pending if IE = 1 in the RNG_CR register. Note: This bit is meaningless if CED (Clock error detection) bit in RNG_CR is equal to 1.",
              "access": "read-write",
              "enum_values": [
                {
                  "name": "Clear",
                  "value": 0,
                  "description": "Clear flag"
                },
                {
                  "name": "Correct",
                  "value": 0,
                  "description": "The RNG clock is correct"
                },
                {
                  "name": "Slow",
                  "value": 1,
                  "description": "The RNG has been detected too slow An interrupt is pending if IE = 1 in the RNG_CR register"
                }
              ]
            },
            {
              "name": "SEIS",
              "bit_offset": 6,
              "bit_width": 1,
              "description": "Seed error interrupt status This bit is set at the same time as SECS. It is cleared by writing it to 0. ** More than 64 consecutive bits at the same value (0 or 1) ** More than 32 consecutive alternances of 0 and 1 (0101010101...01) An interrupt is pending if IE = 1 in the RNG_CR register.",
              "access": "read-write",
              "enum_values": [
                {
                  "name": "NoFault",
                  "value": 0,
                  "description": "No faulty sequence detected"
                },
                {
                  "name": "Fault",
                  "value": 1,
                  "description": "At least one faulty sequence has been detected. See **SECS** bit description for details. An interrupt is pending if IE = 1 in the RNG_CR register."
                }
              ]
            }
